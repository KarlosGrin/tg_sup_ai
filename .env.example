# === Telegram ===
BOT_TOKEN=ваш_токен_бота
CHANNEL_ID=-1004469769190
ADMIN_IDS=123456789,987654321

# === AI Provider: "openai" или "gemini" ===
AI_PROVIDER=openai

# === OpenAI (если AI_PROVIDER=openai) ===
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o
# OPENAI_MAX_TOKENS=4096
# OPENAI_TEMPERATURE=0.3

# === Gemini (если AI_PROVIDER=gemini) ===
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-3-flash-preview

# === Прокси для Telegram API (если api.telegram.org заблокирован) ===
# PROXY_ENABLED=true
# PROXY_URL=socks5://user:pass@host:port
# PROXY_URL=http://user:pass@host:port

# === Альтернативный AI провайдер (опционально) ===
# USE_ALTERNATIVE_AI=true
# ALTERNATIVE_API_KEY=your-key
# ALTERNATIVE_API_URL=https://api.anthropic.com/v1/messages
# ALTERNATIVE_MODEL=claude-3-opus-20240229

# === Режим выполнения ===
# "local" — AI генерирует код, бот выполняет локально (дешевле, требует pandas/openpyxl)
# "assistants" — использует OpenAI Assistants API с Code Interpreter (дороже)
EXECUTION_MODE=local
# OPENAI_ASSISTANT_ID=asst_...  # ID ассистента для Assistants API

# === Пути ===
DOWNLOAD_DIR=downloads
PROCESSED_DIR=processed
MAX_FILE_SIZE_MB=20
