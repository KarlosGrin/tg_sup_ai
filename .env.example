# ═══════════════════════════════════════════════════════════════
# ⚙️  КОНФИГУРАЦИЯ БОТА — скопируйте этот файл в .env
# ═══════════════════════════════════════════════════════════════
# 1. cp .env.example .env
# 2. Отредактируйте .env, вставив реальные ключи
# 3. config.py прочитает .env автоматически через python-dotenv
# ═══════════════════════════════════════════════════════════════

# === Telegram ===
BOT_TOKEN=ваш_токен_бота
CHANNEL_ID=ваш_id_канала_или_оставьте_пустым
ADMIN_IDS=123456789,987654321          # ID админов через запятую

# === AI Provider: "openai" или "gemini" ===
AI_PROVIDER=openai

# === OpenAI (если AI_PROVIDER=openai) ===
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o
# OPENAI_MAX_TOKENS=4096
# OPENAI_TEMPERATURE=0.3

# === Gemini (если AI_PROVIDER=gemini) ===
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-3-flash-preview

# === Прокси для Telegram API (если api.telegram.org заблокирован) ===
# PROXY_ENABLED=true
# PROXY_URL=socks5://user:pass@host:port
# PROXY_URL=http://user:pass@host:port

# === Режим выполнения ===
# "local" — AI генерирует код, бот выполняет локально (через изолированный subprocess)
# "assistants" — Gemini читает файл через File API, код выполняется локально
EXECUTION_MODE=local

# === Пути ===
DOWNLOAD_DIR=downloads
PROCESSED_DIR=processed
MAX_FILE_SIZE_MB=20                     # Максимальный размер загружаемого файла (МБ)

# === Docker-изоляция (рекомендуется для production) ===
# По умолчанию ВКЛЮЧЕНА. Даёт полную изоляцию ОС кода песочницы:
#   --network none, --read-only, --memory=512m, --cpus=1, --cap-drop ALL
# Требует: Docker Desktop, собранный образ (docker compose build sandbox)
# ⚠️ DOCKER_ENABLED=false — прямой subprocess на хосте без изоляции ОС.
#   Используйте ТОЛЬКО для разработки, НЕ для продакшена.
DOCKER_ENABLED=true

# === Таймаут выполнения кода (секунды) ===
EXECUTION_TIMEOUT=120

# === Rate Limiting ===
RATE_LIMIT_REQUESTS_PER_MIN=5          # Максимум AI-запросов в минуту на пользователя
RATE_LIMIT_FILE_UPLOADS_PER_HOUR=20    # Максимум загрузок файлов в час на пользователя
